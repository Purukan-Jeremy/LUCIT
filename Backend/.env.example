SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
FLASK_SECRET_KEY=replace-with-a-long-random-secret
FLASK_ENV=production

# Frontend domain served by Apache
FRONTEND_URL=https://lucit.dev
ALLOWED_ORIGINS=https://lucit.dev

# Session cookie settings for HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_HTTPONLY=true

GEMINI_API_KEY=
GEMINI_DESCRIPTION_MODEL=gemini-2.0-flash
GEMINI_CHAT_MODEL=gemini-1.5-flash

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_SENDER_EMAIL=
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
